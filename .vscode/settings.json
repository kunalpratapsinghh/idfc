{
  "editor.defaultFormatter": "esbenp.prettier-vscode", // Use Prettier as the default formatter
  "editor.formatOnSave": true, // Auto-format on save
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always"
  },

  // Prettier settings based on your requirements
  "prettier.printWidth": 100, // Set line width
  "prettier.singleQuote": false, // Use single quotes
  "prettier.trailingComma": "none", // No trailing commas
  "prettier.semi": false, // Don't auto-add semicolons
  "prettier.arrowParens": "avoid", // Avoid parentheses in single-param arrow functions
  "prettier.bracketSpacing": true, // Spaces between brackets

  // Linting & Formatting for TypeScript and Next.js
  "typescript.preferences.importModuleSpecifier": "relative", // Use relative imports
  "typescript.tsdk": "node_modules/typescript/lib", // Use project-specific TypeScript version
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Ensure ESLint and Prettier work well with ShadCN
  "files.eol": "\n", // Use LF for consistent line endings
  "editor.insertSpaces": true,
  "editor.tabSize": 2,

  // Husky & Lint-staged (ensure hooks run smoothly)
  "git.confirmSync": false, // Auto-sync without confirmation
  "git.enableSmartCommit": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  } // Allow committing without staging all files
}
